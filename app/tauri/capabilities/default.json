{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:webview:allow-set-webview-zoom",
    "os:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        "http://patch.poecdn.com/*",
        "https://patch.poecdn.com/*",
        "http://patch-poe2.poecdn.com/*",
        "https://patch-poe2.poecdn.com/*",
        "https://www.poewiki.net/w/api.php?*",
        "https://www.poe2wiki.net/w/api.php?*",
        "https://poe-versions.obsoleet.org/*",
        "https://github.com/poe-tool-dev/dat-schema/releases/download/*",
        "https://poeladder.com/api/*"
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**"
        }
      ]
    },
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-data-read-recursive",
    "fs:allow-data-write-recursive",
    "fs:allow-document-read-recursive",
    "fs:allow-document-write-recursive"
  ]
}
