{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "@app/*": ["./frontend/*"]
    },
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../frontend/lib/queries.ts",
    "../frontend/lib/stat-descriptions.ts"
  ]
}
